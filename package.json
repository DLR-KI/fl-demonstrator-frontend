{
  "name": "fl-frontend",
  "description": "A frontend for the FL-Demonstrator",
  "version": "1.0.0",
  "private": true,
  "repository": "https://github.com/DLR-KI/fl-demonstrator-frontend",
  "license": "Apache License 2.0 (Apache-2.0)",
  "contributers": [
    "Johannes Unruh <johannes.unruh@dlr.de>",
    "Martin Lanz <martin.lanz@dlr.de>",
    "Tarek Stolz <tarek.stolz@dlr.de>",
    "Florian Heinrich <florian.heinrich@dlr.de>"
  ],
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "build:docker": "docker build -t local/fl-frontend:latest .",
    "build:doc": "uv run mkdocs build",
    "doc": "uv run mkdocs serve",
    "lint": "npm run lint:code && npm run lint:doc",
    "lint:code": "echo 'No code linting configured'",
    "lint:doc": "markdownlint-cli2 -- 'docs/**/*.md' README.md",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.28.2",
    "axios": "^1.14.0",
    "axios-case-converter": "^1.1.1",
    "file-saver": "^2.0.5",
    "leaflet": "^1.9.4",
    "minidenticons": "^4.2.1",
    "particles-bg": "^2.5.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/file-saver": "^2.0.7",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^27.0.0",
    "markdownlint-cli2": "^0.22.0",
    "sass": "^1.99.0",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "smol-toml": "^1.6.1"
  }
}
