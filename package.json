{
  "name": "fl-frontend",
  "description": "A frontend for the FL-Demonstrator",
  "version": "1.0.0",
  "private": true,
  "repository": "https://github.com/DLR-KI/fl-demonstrator-frontend",
  "license": "Apache License 2.0 (Apache-2.0)",
  "contributers": [
    "Johannes Unruh <johannes.unruh@dlr.de>",
    "Martin Lanz <martin.lanz@dlr.de>",
    "Tarek Stolz <tarek.stolz@dlr.de>",
    "Florian Heinrich <florian.heinrich@dlr.de>"
  ],
  "scripts": {
    "start": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api react-scripts start",
    "build": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api react-scripts build",
    "build:docker": "docker build -t local/fl-frontend:latest .",
    "build:doc": "uv run mkdocs build",
    "doc": "uv run mkdocs serve",
    "lint": "npm run lint:code && npm run lint:doc",
    "lint:code": "echo 'No code linting configured'",
    "lint:doc": "markdownlint-cli2 -- 'docs/**/*.md' README.md",
    "test": "cross-env SASS_SILENCE_DEPRECATIONS=legacy-js-api react-scripts test"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "^7.0.1-beta.23",
    "@mui/material": "^7.3.9",
    "@mui/x-charts": "^8.28.2",
    "axios": "^1.14.0",
    "axios-case-converter": "^1.1.1",
    "file-saver": "^2.0.5",
    "http-proxy-middleware": "^3.0.5",
    "leaflet": "^1.9.4",
    "markdownlint-cli2": "^0.22.0",
    "minidenticons": "^4.2.1",
    "particles-bg": "^2.5.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.14.0",
    "react-scripts": "^5.0.1",
    "sass": "^1.99.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@tensorflow/tfjs": "^4.22.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^29.5.14",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "typedoc": "^0.26.11"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
